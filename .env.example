## Agent note:
#never try to access the .env.local file to check for credentials. whatever dummy secrets are here in example file, assume they are also already added in org .env file.


# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=added

# required for non-vercel deployments, vercel uses OIDC automatically
GOOGLE_GENERATIVE_AI_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN="added"

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****



